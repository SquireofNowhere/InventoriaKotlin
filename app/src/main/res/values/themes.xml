<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Application Theme -->
    <style name="Theme.Inventoria" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/purple_secondary</item>
        <item name="colorSecondaryVariant">@color/purple_secondary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Background Colors -->
        <item name="android:colorBackground">@color/light_background</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnSurface">@color/light_on_surface</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Error Colors -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        
        <!-- Window Properties -->
        <item name="android:windowBackground">@color/light_background</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>
    
    <!-- Splash Theme -->
    <style name="Theme.Inventoria.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    
    <!-- Card Style with Purple Sheen -->
    <style name="Widget.Inventoria.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/light_surface</item>
    </style>
    
    <!-- Button Styles -->
    <style name="Widget.Inventoria.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
    </style>
    
    <style name="Widget.Inventoria.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/purple_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/purple_primary</item>
        <item name="android:textAllCaps">false</item>
    </style>
    
    <!-- Text Styles -->
    <style name="TextAppearance.Inventoria.Headline" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/light_on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.Inventoria.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/light_on_surface</item>
    </style>
    
    <style name="TextAppearance.Inventoria.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/light_on_surface_variant</item>
    </style>
</resources>
